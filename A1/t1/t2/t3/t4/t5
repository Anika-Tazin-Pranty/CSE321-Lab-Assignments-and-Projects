#include <stdio.h>
#include <stdlib.h>
#include <sys/wait.h>
#include <unistd.h>

int main(){
  pid_t child_pid, grandchild_pid;

  printf("1. Parent Process Id: %d\n", getpid());

  child_pid = fork();

  if (child_pid < 0){
    perror("Fork Failed");
    exit(1);
    
  }else if (child_pid ==0){
    printf("2. Child Process Id : %d\n", getpid());

    for(int i = 0; i<3; i++){
      grandchild_pid = fork();
      if(grandchild_pid < 0){
        perror("Fork Failed");
        exit(1);
        
      }else if (grandchild_pid ==0){
        printf("%d. Grandchild Process ID : %d\n", i+3, getpid());
        exit(0);
        
      }
    }
    for (int i = 0; i <3; i++){
      wait(NULL);
      
    }
    exit(0);
    
  }
  wait(NULL);
  return 0;
  
}
