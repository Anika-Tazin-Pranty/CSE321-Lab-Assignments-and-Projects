#include <fcntl.h>
#include <stdbool.h> // true/false
#include <stdio.h>
#include <string.h>
#include <unistd.h>

int main() {
  bool flag = true; 

  while (flag == true) {
    int fd;
    char buffer[100];

    
    ssize_t bytesRead = read(0, buffer, sizeof(buffer) - 1);
    if (bytesRead < 0) {
      perror("Error reading input");
      return 1;
    }
    buffer[bytesRead] = '\0'; // Null-terminate the string

    
    fd = open("out.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
    if (fd < 0) {
      perror("Error opening file");
      return 1;
    }

    close(fd);

    printf("%s\n", buffer);

    // Check if input is "-1\n" to stop
    if (strcmp(buffer, "-1\n") == 0) {
      flag = false;
    }
  }

  return 0;
}
